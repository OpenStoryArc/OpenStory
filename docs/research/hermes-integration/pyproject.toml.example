# pyproject.toml for the standalone `hermes-openstory` package.
#
# The load-bearing line is the entry-point declaration at the bottom.
# When this package is pip-installed into the same environment as
# hermes-agent, Hermes's plugin manager auto-discovers it via
# `importlib.metadata.entry_points(group="hermes_agent.plugins")` and
# calls `hermes_openstory.plugin:register`. No upstream code change to
# hermes-agent is required.
#
# Verified at hermes_cli/plugins.py:68:
#     ENTRY_POINTS_GROUP = "hermes_agent.plugins"
# and at hermes_cli/plugins.py:339-358 (PluginManager._scan_entry_points)
# where the actual discovery happens.

[build-system]
requires = ["setuptools>=68", "wheel"]
build-backend = "setuptools.build_meta"

[project]
name = "hermes-openstory"
version = "0.1.0"
description = "OpenStory observability for Hermes Agent — write events to OpenStory and query past sessions via the recall tool."
authors = [{ name = "Open Story contributors" }]
license = { text = "Apache-2.0" }
readme = "README.md"
requires-python = ">=3.10"
dependencies = [
    # Intentionally minimal — the plugin uses only the stdlib for HTTP and
    # JSON. No requests, no httpx, no extra deps.
]

[project.optional-dependencies]
dev = [
    "pytest>=7",
]

# ── The load-bearing entry-point declaration ──────────────────────────────
#
# After `pip install hermes-openstory`, Hermes will discover this entry
# point at startup and call `hermes_openstory.plugin:register(ctx)`.
[project.entry-points."hermes_agent.plugins"]
openstory = "hermes_openstory.plugin:register"

[tool.setuptools.packages.find]
include = ["hermes_openstory*"]
